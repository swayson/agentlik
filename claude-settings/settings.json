{
    "cleanupPeriodDays": 30,
    "env": {
        "BASH_DEFAULT_TIMEOUT_MS": "60000",
        "BASH_MAX_OUTPUT_LENGTH": "20000",
        "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
        "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "20000",
        "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
